[user]
	name = Maarcus Reniero L
	email = maarcusreniero.l@gmail.com

[init]
	defaultBranch = main

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	default = current

[fetch]
	prune = true

[rebase]
	autoStash = true

[rerere]
	enabled = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
	features = catppuccin-mocha

[alias]
	co = checkout
	sw = switch
	st = status --short --branch
	ci = commit
	br = branch
	ds = -c core.pager=delta diff --staged
	d = -c core.pager=delta diff
	lg = log --graph --decorate --oneline --all
	last = log -1 HEAD --stat
	uncommit = reset --soft HEAD~1

# Theme definition for the `catppuccin-mocha` delta feature above.
[include]
	path = ~/dotfiles/git/themes/catppuccin.gitconfig

# Optional machine-local overrides (gitignored, skipped if absent).
[include]
	path = ~/dotfiles/git/local.gitconfig
